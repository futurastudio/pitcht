{
  "name": "pitcht",
  "version": "0.1.0",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently \"next dev\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on http://localhost:3000 dist/electron/main.js && cross-env NODE_ENV=development electron .\"",
    "dev:full": "concurrently \"next dev\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on http://localhost:3000 dist/electron/main.js && cross-env NODE_ENV=development electron .\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron-build": "tsc -p tsconfig.electron.json && electron-builder",
    "verify-env": "node scripts/verify-env.js",
    "pre-deploy": "npm run verify-env && npm run build",
    "smoke-test": "npx tsx scripts/smoke-test.ts",
    "smoke-test:prod": "BASE_URL=https://app.pitcht.us npx tsx scripts/smoke-test.ts",
    "audit:bootstrap": "npx tsx scripts/audit-test-accounts.ts bootstrap",
    "audit:e2e": "npx playwright test --config playwright.audit.config.ts",
    "audit:digest": "npx tsx scripts/audit-digest.ts"
  },
  "build": {
    "appId": "us.pitcht.app",
    "productName": "Pitcht",
    "copyright": "Copyright © 2025 Pitcht",
    "files": [
      "dist/electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "icon": "public/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.education",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Pitcht",
      "icon": "public/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "@mediapipe/camera_utils": "^0.3.1675466862",
    "@mediapipe/face_mesh": "^0.4.1633559619",
    "@mediapipe/tasks-vision": "^0.10.22-rc.20250304",
    "@sentry/nextjs": "^10.28.0",
    "@stripe/stripe-js": "^8.5.3",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.86.0",
    "@vercel/analytics": "^2.0.1",
    "dotenv": "^17.2.3",
    "lucide-react": "^1.11.0",
    "next": "^16.0.7",
    "openai": "^6.9.1",
    "pg": "^8.16.3",
    "posthog-js": "^1.372.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "^3.5.1",
    "sonner": "^2.0.7",
    "stripe": "^20.0.0",
    "twilio": "^5.12.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.0.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  }
}
