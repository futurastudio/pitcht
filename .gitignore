# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Electron build artifacts
/dist/
/electron-dist/
electron/preload.js

# Python services (not deployed to Vercel)
/python-services/

# Documentation and planning files
*.md
!README.md
!CONVERSION_AUDIT_APRIL_2026.md

# Scripts (mostly local-only utilities; opt audit infra in)
/scripts/*
!/scripts/audit-*.ts
!/scripts/audit-*.sql
!/scripts/smoke-test.ts

# Audit run output (Playwright artifacts + JSON)
/audit-artifacts/
/audit-results.json

# Temporary files
/tmp/
*.log

# MCP local config (may contain secret URLs)
.mcp.json

# Electron release output
/release/

# VSCode
/.vscode/
